@public()
func copy () { }
@public()
func compare () bool { return False }

@public()
typedef Alignment {
	_1,
	_2,
	_4,
	_8,
	_16,
	_32
}

from Dotnet.System import { GC }
from Dotnet.System.Runtime.CompilerServices import { RuntimeHelpers }
@public()
func alloc (type T, uint length, Alignment alignment) []T { return GC.AllocateArray(T, length as i32, False) }
@public()
func create (type T, Alignment alignment) T { return RuntimeHelpers.GetUninitializedObject(T) as T }

