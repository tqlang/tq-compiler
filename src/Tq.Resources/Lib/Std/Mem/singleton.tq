from Dotnet.System import { GC }
from Dotnet.System.Runtime.CompilerServices import { RuntimeHelpers }

# Allocates a slice in heap memory
@public func alloc(type T, uint length, Alignment alignment) []T {
    return GC.AllocateArray(T, length as i32, false)
}

# Allocates a struct in heap memory
@public func create(type T, Alignment alignment) T {
    return RuntimeHelpers.GetUninitializedObject(T) as T
}
