from Dotnet.System import { Console }
let string style_reset = "[0m"
let string color_red = "[31m"
let string color_green = "[32m"
func write (i64 value) { Console.Write(value as string) }
func write (u64 value) { Console.Write(value as string) }
func write (i128 value) { Console.Write(value as string) }
func write (u128 value) { Console.Write(value as string) }
func write ([]anytype value) { Console.Write(value as string) }
func write (string value) { Console.Write(value) }
func writeln (i64 value) { Console.WriteLine(value as string) }
func writeln (u64 value) { Console.WriteLine(value as string) }
func writeln (i128 value) { Console.WriteLine(value as string) }
func writeln (u128 value) { Console.WriteLine(value as string) }
func writeln ([]anytype value) { Console.WriteLine(value as string) }
func writeln (string value) { Console.WriteLine(value) }

